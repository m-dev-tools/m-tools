#!/usr/bin/env bash
# ydiff — Show what changed in the database between two points in time.
#
# Usage:
#   ydiff before                     snapshot now → /tmp/ydiff-before.txt
#   ydiff after                      snapshot now → /tmp/ydiff-after.txt; print diff
#   ydiff                            print diff between existing before/after
#   ydiff -- bin/yeval 'do ...'      snapshot, run command, snapshot, print diff
#   ydiff --globals tasks trace      restrict to listed globals (default: yclean groups)
#   ydiff --reset                    delete saved snapshots
#
# Snapshot format is the `raw` flat dump (`^ref=value` per line) produced by
# yexport, sorted for deterministic diffing.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

BEFORE="/tmp/ydiff-before.txt"
AFTER="/tmp/ydiff-after.txt"

# Mirror yclean's default groups so ydiff covers the same surface.
DEFAULT_GLOBALS=(
    tasks taskSeq tasksByDone tasksByFirst
    trace traceSeq lastError
    txnTest txnAcct acct a b
    idxTest indexGbl primaryGbl
    csvTest treeContacts treeDemo treeOrg gname
    demo contacts
)

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

snapshot_to() {
    local outfile="$1"; shift
    local globals=("$@")
    : > "$outfile"
    for g in "${globals[@]}"; do
        "$YDB" -run dump^yutil "$g" >> "$outfile"
    done
    sort -o "$outfile" "$outfile"
}

print_diff() {
    if [[ ! -f "$BEFORE" || ! -f "$AFTER" ]]; then
        echo "ERROR: missing snapshot. Run 'ydiff before' and 'ydiff after' first." >&2
        exit 1
    fi
    if cmp -s "$BEFORE" "$AFTER"; then
        echo "(no changes)"
        return 0
    fi
    # diff -u then re-format each line with +/-/~ markers.
    # `diff` returns 1 when files differ — expected here, so guard with `|| true`.
    { diff -u "$BEFORE" "$AFTER" || true; } | awk '
        /^---|\+\+\+|^@@/ { next }
        /^-/ {
            # Possible delete; might pair with a "+" on the same ref.
            line=substr($0,2)
            n=index(line,"=")
            if (n > 0) { ref=substr(line,1,n-1); val=substr(line,n+1) }
            else       { ref=line; val="" }
            removed[ref]=val
            next
        }
        /^\+/ {
            line=substr($0,2)
            n=index(line,"=")
            if (n > 0) { ref=substr(line,1,n-1); val=substr(line,n+1) }
            else       { ref=line; val="" }
            added[ref]=val
            next
        }
        END {
            for (ref in removed) {
                if (ref in added) {
                    printf "~ %s = %s -> %s\n", ref, removed[ref], added[ref]
                    delete added[ref]
                } else {
                    printf "- %s = %s\n", ref, removed[ref]
                }
            }
            for (ref in added) {
                printf "+ %s = %s\n", ref, added[ref]
            }
        }
    ' | sort
}

# Argument parsing
globals=("${DEFAULT_GLOBALS[@]}")
mode=""
cmd=()

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help)  usage 0 ;;
        --reset)    rm -f "$BEFORE" "$AFTER"; echo "reset"; exit 0 ;;
        --globals)
            shift
            globals=()
            while [[ "$#" -gt 0 && "$1" != --* && "$1" != -- ]]; do
                globals+=("$1"); shift
            done
            continue
            ;;
        --) shift; cmd=("$@"); break ;;
        before|after) mode="$1" ;;
        *) echo "ERROR: unknown arg '$1'" >&2; usage 1 ;;
    esac
    shift
done

if [[ "${#cmd[@]}" -gt 0 ]]; then
    snapshot_to "$BEFORE" "${globals[@]}"
    "${cmd[@]}"
    snapshot_to "$AFTER" "${globals[@]}"
    print_diff
elif [[ "$mode" == "before" ]]; then
    snapshot_to "$BEFORE" "${globals[@]}"
    echo "snapshot saved → $BEFORE"
elif [[ "$mode" == "after" ]]; then
    snapshot_to "$AFTER" "${globals[@]}"
    print_diff
else
    print_diff
fi
