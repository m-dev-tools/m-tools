#!/usr/bin/env bash
# ylog — Stream new ^trace entries as they appear, like `tail -f` for the trace log.
#
# Usage:
#   ylog                   wait for new entries; print as they appear
#   ylog --n 50            print the last 50 entries first, then stream
#   ylog --clear           wipe the log first, then stream
#   ylog --filter PATTERN  only show entries whose context/message matches PATTERN
#
# Polls $$count^trace() at 0.5s intervals; only fetches entries when the count grows.
# Stop with Ctrl-C.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

POLL_INTERVAL="0.5"
backfill_n=0
clear_first=0
filter=""

usage() {
    sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help) usage 0 ;;
        --n)
            shift
            backfill_n="${1:?--n requires a number}"
            ;;
        --clear) clear_first=1 ;;
        --filter)
            shift
            filter="${1:?--filter requires a pattern}"
            ;;
        *)
            echo "ERROR: unknown option '$1'" >&2
            usage 1
            ;;
    esac
    shift
done

current_seq() {
    "$YDB" -run %XCMD 'write $$count^trace()'
}

fetch_range() {
    # Print entries with seq in (from, to]. from is exclusive, to inclusive.
    local from="$1" to="$2"
    if (( to <= from )); then return 0; fi
    local cmd="for s=$((from+1)):1:${to} write s,\".  [\",\$g(^trace(s,\"ctx\"),\"?\"),\"]  \",\$g(^trace(s,\"msg\"),\"?\"),!"
    "$YDB" -run %XCMD "$cmd"
}

emit() {
    if [[ -n "$filter" ]]; then
        grep --line-buffered -E "$filter"
    else
        cat
    fi
}

if (( clear_first )); then
    "$YDB" -run %XCMD 'do clear^trace()'
fi

last="$(current_seq)"

if (( backfill_n > 0 )); then
    from=$(( last - backfill_n ))
    (( from < 0 )) && from=0
    fetch_range "$from" "$last" | emit
fi

echo "── ylog: streaming ^trace from seq ${last} (Ctrl-C to stop) ──" >&2

while true; do
    sleep "$POLL_INTERVAL"
    cur="$(current_seq)"
    if (( cur > last )); then
        fetch_range "$last" "$cur" | emit
        last="$cur"
    fi
done
