#!/usr/bin/env bash
# yci — Run the full CI pipeline: env check, lint, tests.
#
# Usage:
#   yci             run all steps; exit non-zero on first failure
#   yci --fast      skip tests; run env check + lint only
#   yci --report    write a summary line per step to /tmp/yci-report.txt
#
# Pipeline:
#   1. make check-env      verify YDB_DIST and gbldir present
#   2. ycheck --all        syntax-check every routine
#   3. ytest               run all test suites (skipped with --fast)
#
# Exit codes:
#   0 — all steps passed
#   1 — any step failed (process stops at the first failure)

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

fast=0
report=0
report_file="/tmp/yci-report.txt"

usage() {
    sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help) usage 0 ;;
        --fast)    fast=1 ;;
        --report)  report=1 ;;
        *)         echo "ERROR: unknown option '$1'" >&2; usage 1 ;;
    esac
    shift
done

log_step() {
    local status="$1" name="$2" duration="$3"
    printf "[%s] %-12s %ss\n" "$status" "$name" "$duration"
    if (( report )); then
        printf "[%s] %-12s %ss\n" "$status" "$name" "$duration" >> "$report_file"
    fi
}

run_step() {
    local name="$1"; shift
    local start end duration
    start=$(date +%s.%N)
    echo "──────── $name ────────"
    if "$@"; then
        end=$(date +%s.%N)
        duration=$(awk "BEGIN { printf \"%.2f\", $end - $start }")
        log_step "OK  " "$name" "$duration"
    else
        end=$(date +%s.%N)
        duration=$(awk "BEGIN { printf \"%.2f\", $end - $start }")
        log_step "FAIL" "$name" "$duration"
        echo
        echo "yci: pipeline failed at step '$name'"
        exit 1
    fi
    echo
}

if (( report )); then
    : > "$report_file"
    echo "yci report (started $(date -Iseconds))" >> "$report_file"
fi

run_step "check-env" make -C "$PROJ_DIR" check-env
run_step "ycheck"    "$PROJ_DIR/bin/ycheck" --all

if (( fast )); then
    echo "yci: skipping tests (--fast)"
else
    run_step "ytest" "$PROJ_DIR/bin/ytest"
fi

echo "yci: all steps passed"
if (( report )); then
    echo "Report written to $report_file"
fi
