#!/usr/bin/env bash
# ytest — Run one test suite, or one individual test within a suite.
#
# Usage:
#   ytest                        run all suites (delegates to make test)
#   ytest TASKSTST               run one suite
#   ytest tasks                  same — resolves tasks → TASKSTST
#   ytest TASKSTST tAddReturnsId run a single labeled test within a suite
#
# Exit code: 0 if all tests passed, 1 if any failed or the suite was not found.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

usage() {
    sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

resolve_suite() {
    local name="$1"
    name="${name%.m}"
    name="${name##*/}"

    if [[ -f "$PROJ_DIR/routines/tests/${name}.m" ]]; then
        echo "$name"
        return 0
    fi
    local upper="${name^^}"
    if [[ -f "$PROJ_DIR/routines/tests/${upper}.m" ]]; then
        echo "$upper"
        return 0
    fi
    if [[ "$upper" != *TST ]]; then
        local with_tst="${upper}TST"
        if [[ -f "$PROJ_DIR/routines/tests/${with_tst}.m" ]]; then
            echo "$with_tst"
            return 0
        fi
    fi
    return 1
}

run_and_check() {
    # TESTRUN.m's `halt` returns exit 0 even on failure, so detect failure from stdout.
    local tmp
    tmp="$(mktemp)"
    trap 'rm -f "$tmp"' RETURN
    "$@" 2>&1 | tee "$tmp"
    if grep -qE 'test\(s\) FAILED' "$tmp"; then
        return 1
    fi
    return 0
}

case "${1:-}" in
    -h|--help) usage 0 ;;
esac

case "$#" in
    0)
        exec make -C "$PROJ_DIR" test
        ;;
    1)
        suite="$(resolve_suite "$1")" || {
            echo "ERROR: suite '$1' not found in routines/tests/" >&2
            exit 1
        }
        run_and_check "$YDB" -run "^${suite}"
        ;;
    2)
        suite="$(resolve_suite "$1")" || {
            echo "ERROR: suite '$1' not found in routines/tests/" >&2
            exit 1
        }
        label="$2"
        if ! grep -qE "^${label}\(pass,fail\)" "$PROJ_DIR/routines/tests/${suite}.m"; then
            echo "ERROR: label '${label}' not found in ${suite}.m" >&2
            echo "Available tests:" >&2
            grep -oE "^t[A-Za-z0-9]+\(pass,fail\)" "$PROJ_DIR/routines/tests/${suite}.m" \
                | sed 's/(pass,fail)//' | sed 's/^/  /' >&2
            exit 1
        fi
        cmd="new pass,fail  do start^TESTRUN(.pass,.fail)  do ${label}^${suite}(.pass,.fail)  do report^TESTRUN(pass,fail)"
        run_and_check "$YDB" -run %XCMD "$cmd"
        ;;
    *)
        usage 1
        ;;
esac
