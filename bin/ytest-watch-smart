#!/usr/bin/env bash
# ytest-watch-smart — Watch routines/ and re-run only the suite for the
# file that changed (or all suites if no convention match).
#
# Convention: routines/<name>.m       → <NAME>TST suite
#             routines/tests/<X>.m    → <X> suite (run as-is)
#
# Usage:
#   ytest-watch-smart            poll every 1s, pick suite from changed file
#   ytest-watch-smart --all      always run full suite (same as `make watch`)
#   ytest-watch-smart --interval 0.5    set poll interval in seconds
#
# Stop with Ctrl-C. No external deps — pure bash + stat.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

interval="1.0"
mode="smart"

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help)  usage 0 ;;
        --all)      mode="all" ;;
        --interval) shift; interval="${1:?--interval requires seconds}" ;;
        *)          echo "ERROR: unknown option '$1'" >&2; usage 1 ;;
    esac
    shift
done

# Map a changed file path to the test suite that exercises it.
suite_for_file() {
    local file="$1"
    local name suite
    name="$(basename "$file" .m)"
    if [[ "$file" == *"/routines/tests/"* ]]; then
        # File IS a test suite — run it directly.
        echo "$name"
        return 0
    fi
    # Library module — convention: <name>.m → <NAME>TST.m
    suite="${name^^}TST"
    if [[ -f "$PROJ_DIR/routines/tests/${suite}.m" ]]; then
        echo "$suite"
        return 0
    fi
    return 1
}

run_for_change() {
    local file="$1"
    local rel="${file#$PROJ_DIR/}"
    if [[ "$mode" == "all" ]]; then
        echo "── $rel changed → running all suites ──"
        "$PROJ_DIR/bin/ytest" || true
        return
    fi
    if suite="$(suite_for_file "$file")"; then
        echo "── $rel changed → ytest $suite ──"
        "$PROJ_DIR/bin/ytest" "$suite" || true
    else
        echo "── $rel changed → no convention match, running all suites ──"
        "$PROJ_DIR/bin/ytest" || true
    fi
}

declare -A MTIME
snapshot() {
    local f
    MTIME=()
    for f in "$PROJ_DIR"/routines/*.m "$PROJ_DIR"/routines/tests/*.m; do
        [[ -f "$f" ]] || continue
        MTIME[$f]="$(stat -c %Y "$f")"
    done
}

snapshot
echo "ytest-watch-smart: watching ${#MTIME[@]} routines (mode=$mode, interval=${interval}s)"
echo "Stop with Ctrl-C."
echo

while true; do
    sleep "$interval"
    for f in "$PROJ_DIR"/routines/*.m "$PROJ_DIR"/routines/tests/*.m; do
        [[ -f "$f" ]] || continue
        cur="$(stat -c %Y "$f")"
        prev="${MTIME[$f]:-0}"
        if [[ "$cur" != "$prev" ]]; then
            MTIME[$f]="$cur"
            if [[ "$prev" != "0" ]]; then
                run_for_change "$f"
                echo
            fi
        fi
    done
done
