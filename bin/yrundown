#!/usr/bin/env bash
# yrundown — Recover from a dirty YottaDB exit (orphan locks, stuck shared mem).
#
# Usage:
#   yrundown          recover database + clear orphan locks
#   yrundown --dry    show what would run, change nothing
#   yrundown --locks  clear orphan locks only (skip mupip rundown)
#   yrundown --db     run mupip rundown only (skip lke clear)
#
# Wraps:
#   mupip rundown -region "*"   release shared memory + IPC for the region
#   lke clear -all -nointeractive    clear stuck LOCKs left by crashed processes
#
# Safe to run when no other YDB processes are alive. Refuses to run if there
# are other live ydb/mumps processes (would steal their state).

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

dry=0
do_locks=1
do_db=1

usage() {
    sed -n '2,13p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help) usage 0 ;;
        --dry)     dry=1 ;;
        --locks)   do_db=0 ;;
        --db)      do_locks=0 ;;
        *)         echo "ERROR: unknown option '$1'" >&2; usage 1 ;;
    esac
    shift
done

# Refuse if other YDB processes are running (we'd disrupt them).
others=$(pgrep -af 'mumps|yottadb' | grep -v "$$" | grep -v 'yrundown' | grep -v 'pgrep' || true)
if [[ -n "$others" ]]; then
    echo "ERROR: other YDB processes are running:" >&2
    echo "$others" >&2
    echo >&2
    echo "Stop them first, or rerun with explicit confirmation." >&2
    exit 1
fi

run() {
    if (( dry )); then
        echo "DRY: $*"
    else
        echo "→ $*"
        "$@"
    fi
}

if (( do_db )); then
    run "$ydb_dist/mupip" rundown -region "*"
fi
if (( do_locks )); then
    run "$ydb_dist/lke" clear -all -nointeractive
fi

echo "yrundown: complete"
