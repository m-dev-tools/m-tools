#!/usr/bin/env bash
# yglobsize — Report node counts and storage for globals.
#
# Usage:
#   yglobsize                report all known data globals
#   yglobsize tasks trace    report only the named globals
#   yglobsize --all          enumerate every global with data via mupip extract
#   yglobsize --watch        re-run every 2 seconds (Ctrl-C to stop)
#
# Output: one row per global with node count and approximate block usage
# from `mupip size`. Unknown / empty globals are skipped silently.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

# Same default groups as yclean — keeps the two tools in sync.
DEFAULT_GLOBALS=(
    tasks taskSeq tasksByDone tasksByFirst
    trace traceSeq lastError
    txnTest txnAcct acct a b
    idxTest indexGbl primaryGbl
    csvTest treeContacts treeDemo treeOrg gname
    demo contacts
)

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

count_nodes() {
    # Returns node count for ^${1}. 0 if global has no data.
    # Calls count^yutil — argless FOR isn't usable through %XCMD's wrapper.
    "$YDB" -run count^yutil "$1"
}

block_size() {
    # Returns total blocks from `mupip size` for one global, or "—" if unknown.
    # mupip writes to stderr, hence 2>&1.
    local gname="$1"
    local out
    out="$($ydb_dist/mupip size -select="^${gname}" 2>&1 | awk '/^Total/ {print $2; exit}')"
    echo "${out:-—}"
}

list_all_globals() {
    # Use mupip extract -select=* against /dev/null to harvest the global names
    # (extract enumerates all, even if we discard the data).
    local tmp
    tmp="$(mktemp)"
    $ydb_dist/mupip extract -select="*" "$tmp" >/dev/null 2>&1 || true
    awk -F'[(=]' '/^\^/ { sub(/^\^/, "", $1); print $1 }' "$tmp" | sort -u
    rm -f "$tmp"
}

print_table() {
    local globals=("$@")
    printf "%-20s %10s %10s\n" "Global" "Nodes" "Blocks"
    printf "%-20s %10s %10s\n" "──────" "─────" "──────"
    local total=0 g nodes blocks
    for g in "${globals[@]}"; do
        nodes="$(count_nodes "$g")"
        if [[ "$nodes" -eq 0 ]]; then continue; fi
        blocks="$(block_size "$g")"
        printf "^%-19s %10s %10s\n" "$g" "$nodes" "$blocks"
        total=$((total + nodes))
    done
    printf "%-20s %10s\n" "──────" "─────"
    printf "%-20s %10d\n" "Total nodes" "$total"
}

watch=0
mode="default"
case "${1:-}" in
    -h|--help) usage 0 ;;
    --all)     mode="all"; shift ;;
    --watch)   watch=1; shift ;;
esac

case "${1:-}" in
    --watch) watch=1; shift ;;
esac

if [[ "$mode" == "all" ]]; then
    mapfile -t targets < <(list_all_globals)
elif [[ "$#" -gt 0 ]]; then
    targets=("$@")
else
    targets=("${DEFAULT_GLOBALS[@]}")
fi

if (( watch )); then
    while true; do
        clear
        echo "yglobsize --watch  $(date +%H:%M:%S)"
        echo
        print_table "${targets[@]}"
        sleep 2
    done
else
    print_table "${targets[@]}"
fi
