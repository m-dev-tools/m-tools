#!/usr/bin/env bash
# yexport — Export one or more globals to JSON or ZWR for backup/fixtures.
#
# Usage:
#   yexport tasks                    JSON for ^tasks → stdout
#   yexport tasks > tasks.json       save to file
#   yexport tasks trace              merge multiple globals into one JSON array
#   yexport --format zwr tasks       ZWR via mupip extract (round-trips with mupip load)
#   yexport --format raw tasks       flat ref=value lines (round-trips with yseed --raw)
#
# JSON format: an array of {"ref": "<reference>", "value": "<value>"} objects,
# one per node. Round-trips with `yseed`.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

format="json"

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help) usage 0 ;;
        --format)
            shift
            format="${1:?--format requires json|zwr|raw}"
            ;;
        --) shift; break ;;
        -*) echo "ERROR: unknown option '$1'" >&2; usage 1 ;;
        *)  break ;;
    esac
    shift
done

if [[ "$#" -eq 0 ]]; then
    echo "ERROR: at least one global name required" >&2
    usage 1
fi

case "$format" in
    json)
        # Concatenate the per-global arrays into one merged array.
        echo "["
        first=1
        for g in "$@"; do
            inner="$("$YDB" -run exportJson^yutil "$g")"
            inner="${inner#[}"
            inner="${inner%]}"
            inner="${inner%$'\n'}"
            [[ -z "$inner" ]] && continue
            if (( first )); then
                first=0
            else
                echo ","
            fi
            echo -n "$inner"
        done
        echo
        echo "]"
        ;;
    zwr)
        # mupip extract refuses to overwrite — generate a path it can claim.
        tmp="$(mktemp -u)"
        trap 'rm -f "$tmp"' EXIT
        select_pat=""
        for g in "$@"; do
            select_pat+="${select_pat:+,}^${g}*"
        done
        $ydb_dist/mupip extract -select="$select_pat" "$tmp" >&2
        cat "$tmp"
        ;;
    raw)
        for g in "$@"; do
            "$YDB" -run dump^yutil "$g"
        done
        ;;
    *)
        echo "ERROR: unknown --format '$format' (use json|zwr|raw)" >&2
        exit 1
        ;;
esac
