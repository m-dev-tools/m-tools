#!/usr/bin/env bash
# yclean — Wipe test-state globals so tests run from a known clean slate.
#
# Usage:
#   yclean                       wipe all known test-state globals
#   yclean tasks                 wipe only tasks-related globals
#   yclean trace                 wipe only trace globals
#   yclean txn                   wipe only txn-related globals
#   yclean idx                   wipe only idx-related globals
#   yclean fixtures              wipe only ad-hoc test fixture globals
#   yclean demo                  wipe only tutorial/demo globals (^demo, ^contacts)
#   yclean --list                show what each group cleans without running it
#
# Globals are killed via `kill ^global` in a single yeval call.
# Never touches code (.m files), only runtime state.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

# Group definitions — each value is a space-separated list of global names (no ^).
declare -A YCLEAN_GROUPS=(
    [tasks]="tasks taskSeq tasksByDone tasksByFirst"
    [trace]="trace traceSeq"
    [safe]="lastError"
    [txn]="txnTest txnAcct acct a b"
    [idx]="idxTest indexGbl primaryGbl"
    [fixtures]="csvTest treeContacts treeDemo treeOrg gname"
    [demo]="demo contacts"
)

# Order of "all" — matches order user would think about test isolation.
ALL_YCLEAN_GROUPS=(tasks trace safe txn idx fixtures demo)

usage() {
    sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

list_groups() {
    echo "yclean groups:"
    for g in "${ALL_YCLEAN_GROUPS[@]}"; do
        printf "  %-10s  " "$g"
        for name in ${YCLEAN_GROUPS[$g]}; do
            printf "^%s " "$name"
        done
        echo
    done
}

build_kill_cmd() {
    # Args: list of group names
    local cmd="" first=1
    for group in "$@"; do
        if [[ -z "${YCLEAN_GROUPS[$group]:-}" ]]; then
            echo "ERROR: unknown group '$group' (try --list)" >&2
            exit 1
        fi
        for name in ${YCLEAN_GROUPS[$group]}; do
            if (( first )); then
                cmd="kill ^${name}"
                first=0
            else
                cmd="${cmd}  kill ^${name}"
            fi
        done
    done
    echo "$cmd"
}

case "${1:-}" in
    -h|--help) usage 0 ;;
    --list)    list_groups; exit 0 ;;
esac

if [[ "$#" -eq 0 ]]; then
    target_groups=("${ALL_YCLEAN_GROUPS[@]}")
    label="all groups"
else
    target_groups=("$@")
    label="$*"
fi

cmd="$(build_kill_cmd "${target_groups[@]}")"

# Execute the kill commands
"$YDB" -run %XCMD "$cmd"

# Count what's left of the targeted globals (should all be 0)
echo "Cleaned: ${label}"
