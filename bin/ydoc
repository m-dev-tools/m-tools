#!/usr/bin/env bash
# ydoc — Extract Markdown documentation from .m comment blocks.
#
# Usage:
#   ydoc tasks                    print Markdown for routines/tasks.m
#   ydoc --all                    print one section per routine
#   ydoc --all --out docs/api.md  write the combined doc to a file
#
# Convention extracted:
#   - Top-of-file `<routine> ; <description>` becomes the H2 title.
#   - Each label `name(args)` followed by `; <description>` on the same line
#     becomes a function entry. Subsequent comment-only lines starting with
#     `        ;` are appended as the long description.
#   - Test labels (`tXxx`) and `;@TEST` decorations are skipped.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

resolve_file() {
    local name="$1"
    name="${name%.m}"
    name="${name##*/}"
    if   [[ -f "$PROJ_DIR/routines/${name}.m" ]];       then echo "$PROJ_DIR/routines/${name}.m"
    elif [[ -f "$PROJ_DIR/routines/tests/${name}.m" ]]; then echo "$PROJ_DIR/routines/tests/${name}.m"
    else return 1
    fi
}

doc_one() {
    local file="$1"
    awk '
        BEGIN { in_label=0; long_desc="" }
        # Top-of-file: <routine> ; description
        NR==1 && /^[A-Za-z][A-Za-z0-9]*[[:space:]]+;[[:space:]]*/ {
            split($0, parts, ";")
            name=parts[1]
            sub(/[[:space:]]+$/, "", name)
            desc=substr($0, index($0, ";")+1)
            sub(/^[[:space:]]+/, "", desc)
            printf "## `%s`\n\n%s\n\n", name, desc
            next
        }
        # Label line — column-1 identifier, optional (args), maybe ; comment
        /^[A-Za-z][A-Za-z0-9]*(\([^)]*\))?[[:space:]]*(;.*)?$/ {
            line=$0
            sub(/[[:space:]]+$/, "", line)
            comment=""
            sig=line
            n=index(line, ";")
            if (n > 0) {
                sig=substr(line,1,n-1); sub(/[[:space:]]+$/, "", sig)
                comment=substr(line, n+1); sub(/^[[:space:]]+/, "", comment)
            }
            # Skip test labels and @TEST decorations entirely
            if (sig ~ /^t[A-Z]/) { in_label=0; next }
            sub(/^@TEST[[:space:]]*/, "", comment)
            # Flush previous label long-description
            if (in_label && long_desc != "") {
                printf "  %s\n", long_desc
                long_desc=""
            }
            in_label=1
            if (comment != "") {
                printf "\n### `%s`\n\n%s\n", sig, comment
            } else {
                printf "\n### `%s`\n\n", sig
            }
            next
        }
        # Indented comment-only line — treat as long-description continuation
        in_label && /^[[:space:]]+;.*/ {
            line=$0
            sub(/^[[:space:]]+;[[:space:]]*/, "", line)
            sub(/[[:space:]]+$/, "", line)
            if (line != "")
                long_desc = (long_desc == "" ? line : long_desc " " line)
            next
        }
        # Code line — flush any pending long-description and stop adding to it
        in_label && /^[[:space:]]+[^;]/ {
            if (long_desc != "") {
                printf "  %s\n", long_desc
                long_desc=""
            }
            in_label=0
            next
        }
        END {
            if (long_desc != "") printf "  %s\n", long_desc
        }
    ' "$file"
}

mode="one"
out=""
target=""

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help) usage 0 ;;
        --all)     mode="all" ;;
        --out)     shift; out="${1:?--out requires path}" ;;
        -*)        echo "ERROR: unknown option '$1'" >&2; usage 1 ;;
        *)         target="$1" ;;
    esac
    shift
done

emit() {
    if [[ "$mode" == "all" ]]; then
        echo "# YDB Project — Generated API Reference"
        echo
        echo "_Generated by \`ydoc\` from \`routines/*.m\` comments._"
        echo
        for f in "$PROJ_DIR"/routines/*.m; do
            [[ -f "$f" ]] || continue
            doc_one "$f"
            echo
            echo "---"
            echo
        done
    else
        [[ -z "$target" ]] && { echo "ERROR: routine name required" >&2; usage 1; }
        file="$(resolve_file "$target")" || {
            echo "ERROR: routine '$target' not found" >&2; exit 1
        }
        doc_one "$file"
    fi
}

if [[ -n "$out" ]]; then
    emit > "$out"
    echo "wrote $out"
else
    emit
fi
