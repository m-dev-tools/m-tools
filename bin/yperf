#!/usr/bin/env bash
# yperf — Benchmark a MUMPS code snippet.
#
# Usage:
#   yperf 'set x=$$count^tasks()'              run 100 iterations, print stats
#   yperf -n 1000 'set x=1+2+3'                custom iteration count
#   yperf --raw 'set x=1+2+3'                  print per-iteration microseconds
#   yperf --label myop 'set x=...'             prefix the summary line
#
# Output: a one-line summary
#   <label>: N=<iters>  mean=<μs>  median=<μs>  p95=<μs>  min=<μs>  max=<μs>  stddev=<μs>
#
# Includes 3 warmup iterations not counted in the stats. Outliers (>2σ from
# mean) are flagged in the summary count, not removed from raw output.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$PROJ_DIR/scripts/ydb-env.sh"

iters=100
raw=0
label="bench"
code=""

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help) usage 0 ;;
        -n)        shift; iters="${1:?-n requires count}" ;;
        --raw)     raw=1 ;;
        --label)   shift; label="${1:?--label requires name}" ;;
        --)        shift; code="$1"; break ;;
        *)         code="$1" ;;
    esac
    shift
done

[[ -z "$code" ]] && { echo "ERROR: no code supplied" >&2; usage 1; }

times="$("$YDB" -run bench^yutil "${iters}|${code}")"

if (( raw )); then
    echo "$times"
    exit 0
fi

echo "$times" | awk -v iters="$iters" -v label="$label" '
    NR == 1 { min = max = $1 }
    {
        x = $1 + 0
        n++
        sum += x
        sumsq += x * x
        if (x < min) min = x
        if (x > max) max = x
        a[n] = x
    }
    END {
        if (n == 0) { print "no data"; exit 1 }
        mean = sum / n
        # population stddev
        stddev = sqrt(sumsq / n - mean * mean)
        # median + p95 — sort the buffer
        # bubble sort is fine for n<=10000 benchmarks
        for (i = 1; i <= n; i++) for (j = i+1; j <= n; j++) if (a[j] < a[i]) { t = a[i]; a[i] = a[j]; a[j] = t }
        median = (n % 2) ? a[(n+1)/2] : (a[n/2] + a[n/2+1]) / 2
        p95 = a[int(n * 0.95 + 0.5)]
        outliers = 0
        for (i = 1; i <= n; i++) if (a[i] > mean + 2*stddev || a[i] < mean - 2*stddev) outliers++
        printf "%s: N=%d  mean=%.1fμs  median=%.0fμs  p95=%.0fμs  min=%.0fμs  max=%.0fμs  stddev=%.1f  outliers=%d\n",
            label, n, mean, median, p95, min, max, stddev, outliers
    }
'
