#!/usr/bin/env bash
# ytap — Run tests and emit TAP-13 output (Test Anything Protocol).
#
# Usage:
#   ytap                     all suites, TAP to stdout
#   ytap SUITE               one suite
#   ytap SUITE LABEL         one test
#   ytap --out report.tap    write to a file instead of stdout
#
# Transforms the TESTRUN output `PASS desc` / `FAIL desc` lines into
# `ok N - desc` / `not ok N - desc`, with diagnostic `# expected: X`
# / `# actual: Y` lines on failures.

set -euo pipefail

PROJ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

out=""
ytest_args=()

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        -h|--help) usage 0 ;;
        --out)     shift; out="${1:?--out requires path}" ;;
        *)         ytest_args+=("$1") ;;
    esac
    shift
done

emit_tap() {
    "$PROJ_DIR/bin/ytest" "${ytest_args[@]}" 2>&1 | awk '
        BEGIN { print "TAP version 13"; n=0 }
        /^==>/ {
            # Suite divider — emit a TAP comment with the suite name
            sub(/^==> Running /, "")
            sub(/\.\.\.$/, "")
            printf "# suite: %s\n", $0
            next
        }
        /^  PASS  / {
            n++
            sub(/^  PASS  /, "")
            printf "ok %d - %s\n", n, $0
            next
        }
        /^  FAIL  / {
            n++
            sub(/^  FAIL  /, "")
            printf "not ok %d - %s\n", n, $0
            next
        }
        /^         expected: / {
            sub(/^         /, "")
            printf "  # %s\n", $0
            next
        }
        /^         actual:   / {
            sub(/^         /, "")
            printf "  # %s\n", $0
            next
        }
        END { printf "1..%d\n", n }
    '
}

if [[ -n "$out" ]]; then
    emit_tap > "$out"
    echo "wrote $out" >&2
else
    emit_tap
fi
